<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <title>Painel - Foca no Edital</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/style.css">
</head>
<body class="bg-light">
    <nav class="navbar-custom">
        <span class="logo">Foca no Edital</span>
        <div>
            <span class="me-3 fw-bold">Olá, <%= nomeUsuario %>!</span>
            <a href="/logout" class="btn btn-danger btn-sm">Sair</a>
        </div>
    </nav>

    <div class="dashboard-container">
        
        <div class="row mb-4 mt-2">
            <div class="col-md-4">
                <div class="content-card text-center p-3 mb-0 border-primary border-top border-4">
                    <h6 class="text-muted fw-bold mb-1">Editais em Foco</h6>
                    <h2 class="text-primary fw-bold mb-0"><%= totalEditais %></h2>
                </div>
            </div>
            <div class="col-md-4">
                <div class="content-card text-center p-3 mb-0 border-secondary border-top border-4">
                    <h6 class="text-muted fw-bold mb-1">Tópicos para Estudar</h6>
                    <h2 class="text-secondary fw-bold mb-0"><%= totalDisciplinas %></h2>
                </div>
            </div>
            <div class="col-md-4">
                <div class="content-card text-center p-3 mb-0 border-success border-top border-4">
                    <h6 class="text-muted fw-bold mb-1">Tópicos Concluídos</h6>
                    <h2 class="text-success fw-bold mb-0"><%= disciplinasConcluidas %></h2>
                </div>
            </div>
        </div>

        <div class="content-card">
            <h4 class="mb-4 text-primary fw-bold">Adicionar novo Edital</h4>
            
            <form action="/adicionar_edital" method="POST" enctype="multipart/form-data" class="row g-3 align-items-end">
                <div class="col-md-4">
                    <label class="form-label fw-bold text-muted small mb-1">Título</label>
                    <input type="text" name="titulo" class="form-control" placeholder="Ex: IFPB" required>
                </div>
                <div class="col-md-3">
                    <label class="form-label fw-bold text-muted small mb-1">Data da Prova</label>
                    <input type="date" name="data_prova" class="form-control" required>
                </div>
                <div class="col-md-3">
                    <label class="form-label fw-bold text-muted small mb-1">Anexar Edital (Para IA)</label>
                    <input type="file" name="arquivo_pdf" accept="application/pdf" class="form-control">
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-success w-100">+ Adicionar</button>
                </div>
            </form>
        </div>

        <h3 class="mb-4 fw-bold mt-5">Meus Editais</h3>
        <div class="row">
            <% editais.forEach(function(edital) { %>
            <div class="col-md-4 mb-4">
                <div class="edital-card position-relative d-flex flex-column h-100">
                    
                    <% if (edital.arquivo_pdf) { %>
                        <span class="badge bg-warning text-dark position-absolute top-0 start-50 translate-middle rounded-pill border border-white">
                            IA Ativa
                        </span>
                    <% } %>

                    <div class="d-flex justify-content-between align-items-start mt-2">
                        <h5 class="fw-bold text-primary"><%= edital.titulo %></h5>
                        <div>
                            <a href="/editar_edital/<%= edital.id %>" class="text-secondary text-decoration-none me-2">✏️</a>
                            <a href="/excluir_edital/<%= edital.id %>" class="text-danger text-decoration-none" onclick="return confirm('Excluir edital?');">🗑️</a>
                        </div>
                    </div>
                    
                    <p class="text-muted small mb-3">Prova em: <strong><%= edital.data_prova %></strong></p>
                    
                    <div class="mb-4">
                        <div class="d-flex justify-content-between mb-1">
                            <span class="small fw-bold text-secondary">Progresso dos Estudos</span>
                            <span class="small fw-bold text-success"><%= edital.progresso %>%</span>
                        </div>
                        <div class="progress" style="height: 8px;">
                            <div class="progress-bar bg-success" role="progressbar" style="width: <%= edital.progresso %>%"></div>
                        </div>
                    </div>

                    <div class="d-flex gap-2 mt-auto">
                        <a href="/disciplinas/<%= edital.id %>" class="btn btn-primary flex-grow-1">Acessar Matérias</a>
                        
                        <% if (edital.arquivo_pdf) { %>
                            <a href="/baixar_edital/<%= edital.id %>" class="btn btn-outline-secondary" target="_blank" title="Ler PDF">📄 PDF</a>
                        <% } %>
                    </div>

                </div>
            </div>
            <% }); %>
        </div>

    </div>
</body>
</html>