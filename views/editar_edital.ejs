<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <title>Editar Edital</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/style.css">
</head>
<body class="bg-light">
    <nav class="navbar-custom">
        <a href="/dashboard" class="logo">← Cancelar e Voltar</a>
    </nav>

    <div class="dashboard-container">
        <div class="content-card">
            <h4 class="mb-4 text-primary fw-bold">Editar Edital</h4>
            <form action="/editar_edital/<%= edital.id %>" method="POST">
                <div class="mb-3">
                    <label class="form-label fw-bold">Título do Edital</label>
                    <input type="text" name="titulo" class="form-control" value="<%= edital.titulo %>" required>
                </div>
                <div class="mb-4">
                    <label class="form-label fw-bold">Data da Prova</label>
                    <input type="date" name="data_prova" class="form-control" value="<%= edital.data_prova %>" required>
                </div>
                <button type="submit" class="btn btn-primary w-100">Salvar Alterações</button>
            </form>
        </div>
    </div>
</body>
</html>