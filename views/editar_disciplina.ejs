<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <title>Editar Disciplina</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/style.css">
</head>
<body class="bg-light">
    <nav class="navbar-custom">
        <a href="/disciplinas/<%= id_edital %>" class="logo">← Cancelar e Voltar</a>
    </nav>

    <div class="dashboard-container">
        <div class="content-card">
            <h4 class="mb-4 text-primary fw-bold">Editar Matéria</h4>
            
            <form action="/editar_disciplina/<%= disciplina.id %>/<%= id_edital %>" method="POST">
                <div class="mb-3">
                    <label class="form-label fw-bold">Nome da Matéria</label>
                    <input type="text" name="nome_materia" class="form-control" value="<%= disciplina.nome_materia %>" required>
                </div>
                <div class="mb-4">
                    <label class="form-label fw-bold">Status do Estudo</label>
                    <select name="status" class="form-control">
                        <option value="Pendente" <%= disciplina.status === 'Pendente' ? 'selected' : '' %>>Pendente</option>
                        <option value="Concluído" <%= disciplina.status === 'Concluído' ? 'selected' : '' %>>Concluído</option>
                    </select>
                </div>
                <button type="submit" class="btn btn-primary w-100">Atualizar Matéria</button>
            </form>
        </div>
    </div>
</body>
</html>